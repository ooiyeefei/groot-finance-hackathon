    await ctx.db.insert("accounting_entries", {
      businessId,
      userId,
      transactionType: "Expense",
      category: "Bills",
      originalAmount: 5000,
      originalCurrency: homeCurrency,
      homeCurrencyAmount: 5000,
      homeCurrency: homeCurrency,
      transactionDate: daysAgo(25),
      dueDate: daysFromNow(3),
      description: "Insurance payment - URGENT",
      vendorName: "Insurance Corp",
      status: "pending",
    });

    console.log("✅ Test data seeded");

    // Step 5: Schedule proactive analysis (will run async)
    console.log("📊 Scheduling proactive analysis...");
    await ctx.scheduler.runAfter(0, internal.functions.actionCenterJobs.runProactiveAnalysis, {});

    console.log("🎉 Dev setup complete!");

    return {
