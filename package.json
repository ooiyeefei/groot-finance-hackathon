{
  "name": "finanseal-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "npm run setup:python",
    "predev": "npm run setup:python",
    "dev": "next dev",
    "prebuild": "npm run setup:python && npm run lint:translations",
    "build": "next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "lint": "next lint",
    "lint:translations": "node scripts/translations/validate-translations.js",
    "type-check": "tsc --noEmit",
    "validate-translations": "node scripts/translations/validate-translations.js",
    "migrate:backfill": "tsx src/scripts/migrations/backfill_transaction_data.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf .next",
    "setup:python": "./scripts/setup-python.sh",
    "build:full": "npm run clean && npm run setup:python && npm install && npm run build && npm run dev",
    "build:with-python": "npm run setup:python && npm install && npm run build",
    "dev:fresh": "rm -rf .next && npm run setup:python && npm install && npm run build && npm run dev",
    "perf:build": "npm run build && npm run build:analyze",
    "perf:lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=lighthouse-report.html --chrome-flags='--headless'",
    "analyze:dead-code": "node scripts/analyze-dead-code.js",
    "analyze:bundle": "npm run build:analyze && echo 'Open .next/analyze/client.html'",
    "analyze:dependencies": "npx madge --circular src/ && npx dependency-cruiser --validate .dependency-cruiser.js src || echo 'dependency-cruiser config needed'",
    "clean:unused-exports": "npx ts-prune --project ./tsconfig.json | grep -v 'used in module' > unused-exports.txt",
    "lint:unused-imports": "npx eslint src/ --ext .ts,.tsx --fix --rule 'unused-imports/no-unused-imports: error' || echo 'unused-imports plugin needed'"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.30.0",
    "@google/genai": "^1.19.0",
    "@heroicons/react": "^2.2.0",
    "@huggingface/inference": "^4.6.1",
    "@langchain/core": "^0.3.70",
    "@langchain/langgraph": "^0.4.5",
    "@langchain/openai": "^0.6.7",
    "@qdrant/js-client-rest": "^1.15.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.54.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@trigger.dev/python": "4.0.5",
    "@trigger.dev/sdk": "4.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "google-spreadsheet": "^5.0.2",
    "html2pdf.js": "^0.12.1",
    "jose": "^6.1.0",
    "langchain": "^0.3.30",
    "lucide-react": "^0.539.0",
    "next": "^15.5.6",
    "next-intl": "^4.4.0",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.1.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "resend": "^6.0.2",
    "sharp": "^0.34.3",
    "svix": "^1.76.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^15.5.6",
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@trigger.dev/build": "4.0.5",
    "@types/html2pdf.js": "^0.10.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "dependency-cruiser": "^16.10.4",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "eslint-plugin-unused-imports": "^4.2.0",
    "jsdom": "^27.0.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.6",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.17",
    "ts-prune": "^0.10.3",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "trigger.dev": {
    "endpointId": "proj_qjsdxdsoxmrgplspwuwj"
  }
