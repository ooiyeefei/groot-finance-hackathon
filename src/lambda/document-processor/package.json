{
  "name": "finanseal-document-processor",
  "version": "1.0.0",
  "description": "Lambda Durable Function for document processing",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node22 --outdir=dist --external:@aws-sdk/*",
    "build:watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@google/generative-ai": "^0.21.0",
    "@sentry/aws-serverless": "^8.42.0",
    "convex": "^1.17.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.2",
    "typescript": "~5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
