# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.trigger

# AWS CDK
cdk.out/
infra/cdk.out/

# Lambda build artifacts
**/dist/
src/lambda/**/dist/

# Convex backup (prod data exports)
.convex-backup/

# LangGraph API
.langgraph_api

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# Python knowledge base artifacts
src/scripts/knowledge_base/venv/
src/scripts/knowledge_base/output/
src/scripts/knowledge_base/__pycache__/
src/scripts/knowledge_base/*.log

# clerk configuration (can include secrets)
/.clerk/
.env*.local
firebase-debug.log

# Playwright MCP debugging screenshots
.playwright-mcp/

# UAT/test screenshots — never commit images to repo
uat-*.png
*.screenshot.png

# PWA Service Worker (auto-generated during build)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map

# TypeScript compilation artifacts (should not be in src/)
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
src/**/*.d.ts.map
!src/**/*.config.js

# Convex default boilerplate
convex/README.md

# CloudFront signing keys
secrets/

# Database dumps and backups (use proper backup tooling, not git)
*_backup.sql
*_data.sql
*.sql.bak
PRODUCTION_MIGRATION_SCRIPT.sql

# Binary test fixtures (large files that bloat history)
tests/fixtures/**/*.PF3
test/data/*.pdf
