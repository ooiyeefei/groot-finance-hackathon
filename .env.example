# FinanSEAL Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# ==============================================================================
# SUPABASE DATABASE
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ==============================================================================
# CLERK AUTHENTICATION
# ==============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# Force redirect after sign-in/sign-up (works with Account Portal)
# Reference: https://clerk.com/docs/guides/account-portal/direct-links
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/

# NOTE: Subdomain authentication works automatically when root domain (hellogroot.com)
# is configured in Clerk Dashboard. Custom sign-in/sign-up pages handle redirects
# to the centralized Account Portal (accounts.hellogroot.com).

# Test credentials (development only)
TEST_USER=your_test_email@example.com
TEST_USER_PW=your_test_password

# ==============================================================================
# REDIS CACHING & RATE LIMITING (OPTIONAL - Production Recommended)
# ==============================================================================
# Upstash Redis for:
# - Distributed caching (business context, JWT tokens, user roles)
# - Distributed rate limiting across serverless instances
# Get your credentials from: https://upstash.com/
# If not configured, the system will automatically fall back to in-memory caching/rate limiting
# See: src/lib/cache/REDIS_CACHING.md for full documentation
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ==============================================================================
# SECURITY KEYS
# ==============================================================================
# Key for securing internal service-to-service API calls
INTERNAL_SERVICE_KEY=your_internal_service_key

# Master admin key for SaaS owner operations
MASTER_ADMIN_KEY=your_master_admin_key

# ==============================================================================
# EMAIL SERVICE (RESEND)
# ==============================================================================
RESEND_API_KEY=your_resend_api_key

# ==============================================================================
# VECTOR DATABASE (QDRANT)
# ==============================================================================
QDRANT_URL=your_qdrant_url
QDRANT_API_KEY=your_qdrant_api_key

# ==============================================================================
# BACKGROUND JOBS (TRIGGER.DEV)
# ==============================================================================
TRIGGER_SECRET_KEY=your_trigger_secret_key

# ==============================================================================
# AWS LAMBDA DURABLE FUNCTIONS (Document Processing)
# ==============================================================================
# Feature flag to enable Lambda processing (set to "true" to use Lambda instead of Trigger.dev)
USE_LAMBDA_PROCESSING=false

# Lambda function ARN for document processing
# Format: arn:aws:lambda:{region}:{account-id}:function:{function-name}
DOCUMENT_PROCESSOR_LAMBDA_ARN=arn:aws:lambda:us-west-2:837224017779:function:finanseal-document-processor

# AWS IAM Role ARN that Vercel can assume via OIDC
# The role must have lambda:InvokeFunction permission for the Lambda function above
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/vercel-oidc-role

# AWS Region for Lambda function
AWS_REGION=ap-southeast-1

# Vercel OIDC Configuration (automatically set by Vercel)
# VERCEL_OIDC_TOKEN - automatically injected by Vercel at runtime

# ==============================================================================
# OBSERVABILITY (LANGSMITH)
# ==============================================================================
LANGSMITH_API_KEY=your_langsmith_api_key

# ==============================================================================
# AI MODEL ENDPOINTS
# ==============================================================================
# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# OCR Endpoint for Document Processing
OCR_ENDPOINT_URL=your_ocr_endpoint_url
OCR_MODEL_NAME=your_ocr_model_name

# Embedding Model Endpoint
EMBEDDING_ENDPOINT_URL=your_embedding_endpoint_url
EMBEDDING_MODEL_ID=your_embedding_model_id
EMBEDDING_API_KEY=your_embedding_api_key

# SEA-LION Language Model Endpoint
SEALION_ENDPOINT_URL=your_sealion_endpoint_url
SEALION_MODEL_ID=your_sealion_model_id

# Chat Model Configuration
CHAT_MODEL_ENDPOINT_URL=your_chat_model_endpoint_url
CHAT_MODEL_MODEL_ID=your_chat_model_model_id
CHAT_MODEL_API_KEY=your_chat_model_api_key

# ==============================================================================
# STRIPE BILLING
# ==============================================================================
# Stripe API keys - Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook secret - Generated by Stripe CLI or Dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Product Price IDs - Create products in Stripe Dashboard
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# ==============================================================================
# ERROR MONITORING (SENTRY)
# ==============================================================================
# Sentry DSN - Get from https://sentry.io/settings/projects/{project}/keys/
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Sentry Auth Token - Required for source map upload during build
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, project:write, org:read
SENTRY_AUTH_TOKEN=sntrys_xxx

# Sentry Organization and Project slugs
# Find at: sentry.io/organizations/{org-slug}/projects/{project-slug}/
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Sentry API Key - For programmatic configuration (alerts, webhooks)
# Required scopes: alerts:read, alerts:write, project:read, project:write, org:read
SENTRY_API_KEY=your_sentry_api_key

# Sentry Webhook Secret - For validating incoming Sentry webhooks
# Generate a secure random string (e.g., openssl rand -hex 32)
SENTRY_WEBHOOK_SECRET=your_sentry_webhook_secret

# ==============================================================================
# ALERT FORWARDING (TELEGRAM)
# ==============================================================================
# Telegram Bot for error alert forwarding from Sentry
# 1. Create bot via @BotFather: https://t.me/botfather
# 2. Get bot token from BotFather
# 3. Create a group/channel and add the bot
# 4. Get chat_id by messaging the bot and checking: https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
# Local: http://localhost:3000 (with Clerk dev instance keys)
# Prod:  https://finance.hellogroot.com (with Clerk prod instance keys)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# File Upload Limits
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_SUPPORTED_FORMATS=image/jpeg,image/png,application/pdf

# Document Classification Types
SUPPORTED_OCR_DOC_TYPE=invoice,ic,payslip,application_form
