# FinanSEAL Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# ==============================================================================
# SUPABASE DATABASE
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ==============================================================================
# CLERK AUTHENTICATION
# ==============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# NOTE: Subdomain authentication works automatically when root domain (hellogroot.com)
# is configured in Clerk Dashboard. Custom sign-in/sign-up pages handle redirects
# to the centralized Account Portal (accounts.hellogroot.com).

# Test credentials (development only)
TEST_USER=your_test_email@example.com
TEST_USER_PW=your_test_password

# ==============================================================================
# REDIS CACHING & RATE LIMITING (OPTIONAL - Production Recommended)
# ==============================================================================
# Upstash Redis for:
# - Distributed caching (business context, JWT tokens, user roles)
# - Distributed rate limiting across serverless instances
# Get your credentials from: https://upstash.com/
# If not configured, the system will automatically fall back to in-memory caching/rate limiting
# See: src/lib/cache/REDIS_CACHING.md for full documentation
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ==============================================================================
# SECURITY KEYS
# ==============================================================================
# Key for securing internal service-to-service API calls
INTERNAL_SERVICE_KEY=your_internal_service_key

# Master admin key for SaaS owner operations
MASTER_ADMIN_KEY=your_master_admin_key

# ==============================================================================
# EMAIL SERVICE (RESEND)
# ==============================================================================
RESEND_API_KEY=your_resend_api_key

# ==============================================================================
# VECTOR DATABASE (QDRANT)
# ==============================================================================
QDRANT_URL=your_qdrant_url
QDRANT_API_KEY=your_qdrant_api_key

# ==============================================================================
# BACKGROUND JOBS (TRIGGER.DEV)
# ==============================================================================
TRIGGER_SECRET_KEY=your_trigger_secret_key

# ==============================================================================
# OBSERVABILITY (LANGSMITH)
# ==============================================================================
LANGSMITH_API_KEY=your_langsmith_api_key

# ==============================================================================
# AI MODEL ENDPOINTS
# ==============================================================================
# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# OCR Endpoint for Document Processing
OCR_ENDPOINT_URL=your_ocr_endpoint_url
OCR_MODEL_NAME=your_ocr_model_name

# Embedding Model Endpoint
EMBEDDING_ENDPOINT_URL=your_embedding_endpoint_url
EMBEDDING_MODEL_ID=your_embedding_model_id
EMBEDDING_API_KEY=your_embedding_api_key

# SEA-LION Language Model Endpoint
SEALION_ENDPOINT_URL=your_sealion_endpoint_url
SEALION_MODEL_ID=your_sealion_model_id

# Chat Model Configuration
CHAT_MODEL_ENDPOINT_URL=your_chat_model_endpoint_url
CHAT_MODEL_MODEL_ID=your_chat_model_model_id
CHAT_MODEL_API_KEY=your_chat_model_api_key

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# File Upload Limits
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_SUPPORTED_FORMATS=image/jpeg,image/png,application/pdf

# Document Classification Types
SUPPORTED_OCR_DOC_TYPE=invoice,ic,payslip,application_form
